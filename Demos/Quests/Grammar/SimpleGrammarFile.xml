<?xml version="1.0" encoding="utf-8"?>
<grammar xml:lang="es-CL" root="Quest" version="1.0" xmlns="http://www.w3.org/2001/06/grammar">

  <rule id="Quest">
    <one-of>
      <item> <ruleref uri="#Subquest" /> </item>
      <item> <ruleref uri="#Goto" /> </item>
      <item> <ruleref uri="#Learn" /> </item>
      <item> <ruleref uri="#Get" /> </item>
      <item> <ruleref uri="#Steal" /> </item>
      <item> <ruleref uri="#Kill" /> </item>
      <item> <ruleref uri="#Capture" /> </item>
      <item> <ruleref uri="#Spy" /> </item>
    </one-of>
  </rule>

  <rule id="Subquest">
    <one-of>
      <item> <ruleref uri="#Goto" /> </item>
      <item> <ruleref uri="#Goto" /> <ruleref uri="#Quest" /> go to </item>
    </one-of>
  </rule>

  <rule id="Goto">
    <one-of>
      <item> explore </item>
      <item> <ruleref uri="#Learn" /> go to </item>
      <item> go to </item>
    </one-of>
  </rule>

  <rule id="Learn">
    <one-of>
      <item> <ruleref uri="#Goto" /> <ruleref uri="#Subquest" /> listen </item>
      <item> <ruleref uri="#Goto" /> <ruleref uri="#Get" /> read </item>
      <item> <ruleref uri="#Get" /> <ruleref uri="#Subquest" />  <item> give </item> listen </item>
    </one-of>
  </rule>

  <rule id="Get">
    <one-of>
      <item> <ruleref uri="#Steal" /> </item>
      <item> <ruleref uri="#Goto" /> gather </item>
      <item> <ruleref uri="#Goto" /> <ruleref uri="#Get" /> <ruleref uri="#Goto" /> <ruleref uri="#Subquest" /> exchange </item>
    </one-of>
  </rule>

  <rule id="Steal">
    <one-of>
      <item> <ruleref uri="#Goto" /> <item> stealth </item> take </item>
      <item> <ruleref uri="#Goto" /> <ruleref uri="#Kill" /> take </item>
    </one-of>
  </rule>

  <rule id="Kill">
    <one-of>
      <item> <ruleref uri="#Goto" /> kill </item>
    </one-of>
  </rule>

  <rule id="Capture">
    <one-of>
      <item> <ruleref uri="#Get" /> <ruleref uri="#Goto" /> capture </item>
    </one-of>
  </rule>

  <rule id="Spy">
    <one-of>
      <item> <ruleref uri="#Goto" /> spy <ruleref uri="#Goto" /> report </item>
    </one-of>
  </rule>

	<terminal id="take">
		<field type="referenceType" name="Item Type" />
		<field type="int" name="Item Amount" />
		<field type="referenceGraph" name="Item in Level" />
		<field type="List.int" name="Item Prices"/>
		<field type="string" name="item name" />
	</terminal>

</grammar>


<!--
Field types for terminal. If you want to add fields to terminal, they must be part of the grammar field
existing classes, these can be expanded upon in case new data wants to be gathere. the default supported
types are:

PRIMITIVE TYPES
/>
int
    Stores whole numbers.

        Example:
            <field type="int" name="Amount" />

float
    Stores decimal numbers.

        Example:
            <field type="float" name="Speed" />

string
    Stores text.

        Example:
            <field type="string" name="NPC Name" />}

referenceType
    Stores a Bundle/Object type identifier (string/class type reference).

    Example:
        <field type="referenceType" name="Enemy Type" />

referenceGraph
    Stores a graph target / in-level reference.

        Example:
            <field type="referenceGraph" name="Target Location" />


SPECIAL TYPES

eventHook
    Stores an event hooker callback/action.

        Example:
            <field type="eventHook" name="On Complete" />

area
    Stores a Rect area (x,y,width,height).

        Example:
            <field type="area" name="Spawn Area" />


LIST TYPES

List.int
    List of integer fields.

        Example:
            <field type="List.int" name="Rewards" />

List.float
    List of float fields.

        Example:
            <field type="List.float" name="Drop Chances" />

List.string
    List of string fields.

        Example:
            <field type="List.string" name="Dialogue Lines" />

List.referenceType
    List of type references.

    Example:
        <field type="List.referenceType" name="Allowed Enemy Types" />

List.referenceGraph
    List of graph references.

    Example:
        <field type="List.referenceGraph" name="Patrol Points" />



Terminal Definition Example
<terminal id="take">
    <field type="referenceType" name="Item Type" />
    <field type="int" name="Item Amount" />
    <field type="referenceGraph" name="Item In Level" />
    <field type="List.int" name="Item Prices" />
    <field type="string" name="Item Name" />
</terminal>
-->