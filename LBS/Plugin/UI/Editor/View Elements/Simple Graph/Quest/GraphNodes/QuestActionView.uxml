<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <Style src="project://database/Assets/ISILab/LBS/Plugin/UI/Styles/QuestNodesStyle.uss?fileID=7433441132597879392&amp;guid=afa2cfcdd1f21a240afd8be6009458ab&amp;type=3#QuestNodesStyle" />
    <ui:VisualElement style="flex-grow: 0; flex-direction: row; align-self: stretch; max-height: initial; max-width: initial; align-items: stretch; justify-content: space-around;">
        <ui:VisualElement name="Root" focusable="false" class="node" style="flex-grow: 1; position: relative; flex-direction: row; flex-shrink: 0; border-left-width: 0; border-right-width: 0; border-top-width: 0; border-bottom-width: 0; border-left-color: rgba(255, 255, 255, 0); border-right-color: rgba(255, 255, 255, 0); border-top-color: rgba(255, 255, 255, 0); border-bottom-color: rgba(255, 255, 255, 0); min-height: 32px; max-height: none; border-top-left-radius: 0; border-top-right-radius: 0; border-bottom-right-radius: 0; border-bottom-left-radius: 0; align-self: stretch; align-content: auto; justify-content: flex-start; align-items: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; min-width: auto; background-color: rgba(48, 48, 48, 0);">
            <ISILab.LBS.VisualElements.QuestActionDetailsView name="TooltipWindow" style="position: absolute; top: -4px; left: -16px; height: auto; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgba(0, 0, 0, 0.33); border-right-color: rgba(0, 0, 0, 0.33); border-top-color: rgba(0, 0, 0, 0.33); border-bottom-color: rgba(0, 0, 0, 0.33); background-color: rgb(47, 47, 47); -unity-text-outline-color: rgb(32, 32, 32); width: 380px; scale: 1 1; display: flex;" />
            <ui:VisualElement name="StartVe" tooltip="This is the starting node of the graph." style="flex-grow: 1; background-image: resource(&apos;Icons/Vectorial/QuestIcons/Quest=Start&apos;); -unity-background-scale-mode: scale-to-fit; position: relative; height: 46px; width: 47px; top: 0; left: 0; align-self: center; align-items: stretch;" />
            <ui:VisualElement name="Capsule" style="width: auto; justify-content: flex-end; align-items: stretch; align-self: stretch; overflow: hidden; flex-direction: row; flex-shrink: 1; align-content: auto; max-width: none; min-width: auto; flex-grow: 1; margin-right: 0; margin-left: 0; margin-top: 0; margin-bottom: 0; padding-top: 6px; padding-right: 6px; padding-bottom: 6px; padding-left: 6px; border-top-left-radius: 16px; border-top-right-radius: 16px; border-bottom-right-radius: 16px; border-bottom-left-radius: 16px; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgba(255, 255, 255, 0.3); border-right-color: rgba(255, 255, 255, 0.3); border-top-color: rgba(255, 255, 255, 0.3); border-bottom-color: rgba(255, 255, 255, 0.3); background-color: rgb(48, 48, 48);">
                <ui:VisualElement name="ScrollIcon" focusable="true" class="node-status" style="background-image: resource(&apos;Icons/Vectorial/QuestIcons/Quest=Scroll&apos;); min-height: 18px; min-width: 18px; -unity-background-image-tint-color: rgb(255, 255, 255); display: flex; justify-content: space-between; align-self: center; margin-top: 2px; margin-right: 2px; margin-bottom: 2px; margin-left: 6px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; max-width: 18px; max-height: 18px; flex-grow: 1;" />
                <ui:VisualElement name="Icon" picking-mode="Ignore" class="node-icon" style="background-image: resource(&apos;Icons/Vectorial/QuestIcons/GrammarAssistant/Icon=QuestNode&apos;); align-self: center; max-height: 20px; min-height: 20px; max-width: 20px; min-width: 20px; -unity-background-scale-mode: scale-to-fit; background-size: 100% 100%; margin-left: 12px; display: none;" />
                <ui:Label text="Action" display-tooltip-when-elided="true" name="Title" picking-mode="Ignore" style="align-self: center; justify-content: flex-start; -unity-text-align: middle-left; min-height: 20px; max-height: 20px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-shrink: 1; font-size: 16px;" />
                <ui:VisualElement name="InvalidDataIcon" focusable="true" class="node-status" style="background-image: resource(&apos;Icons/Vectorial/QuestIcons/Icon=Warning&apos;); min-height: 24px; min-width: 24px; height: auto; width: auto; justify-content: space-between; align-self: center; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px; background-size: 100% 100%; margin-top: 3px; margin-right: 3px; margin-bottom: 3px; margin-left: 3px; max-width: 24px; max-height: 24px; flex-grow: 1; -unity-background-scale-mode: scale-to-fit;" />
                <ui:VisualElement name="InvalidGrammarIcon" focusable="true" class="node-status" style="background-image: resource(&apos;Icons/Vectorial/QuestIcons/Icon=Error&apos;); min-height: 24px; min-width: 24px; height: auto; width: auto; justify-content: space-between; align-self: center; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px; background-size: 100% 100%; margin-top: 2px; margin-right: 2px; margin-bottom: 2px; margin-left: 2px; max-width: 24px; max-height: 24px; flex-grow: 1; -unity-background-scale-mode: scale-to-fit;" />
                <ui:VisualElement name="InvalidConnectionIcon" focusable="true" class="node-status" style="background-image: resource(&apos;Icons/Vectorial/Manipulators/Icon=QuestConnection&apos;); min-height: 24px; min-width: 24px; height: auto; width: auto; justify-content: space-between; align-self: center; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px; background-size: 100% 100%; margin-top: 2px; margin-right: 6px; margin-bottom: 2px; margin-left: 2px; max-width: 24px; max-height: 24px; flex-grow: 1; -unity-background-scale-mode: scale-to-fit;" />
                <uie:ToolbarMenu tabindex="-1" display-tooltip-when-elided="true" name="ToolBar" picking-mode="Ignore" tooltip="Right click to set as Start Node." class="unity-toolbar-menu" style="height: 44px; width: 186px; position: absolute; top: 0; left: -2px; display: flex; background-color: rgba(60, 60, 60, 0); border-left-width: 0; border-right-width: 0; border-top-width: 0; border-bottom-width: 0; visibility: hidden;" />
            </ui:VisualElement>
            <ui:VisualElement name="GoalVe" tooltip="This an End node of the graph." style="flex-grow: 1; background-image: resource(&apos;Icons/Vectorial/QuestIcons/Quest=Goal&apos;); -unity-background-scale-mode: scale-to-fit; position: relative; height: 46px; width: 47px; top: 0; left: 0; align-items: stretch; align-self: center;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
