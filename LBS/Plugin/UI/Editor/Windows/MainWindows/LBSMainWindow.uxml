<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <Style src="project://database/Assets/ISILab/LBS/Plugin/UI/Styles/LBSstyle.uss?fileID=7433441132597879392&amp;guid=9614f5340894b3546b59d43b5f2be029&amp;type=3#LBSstyle" />
    <Style src="project://database/Assets/ISILab/LBS/Plugin/UI/Styles/LBSOverrideStyle.uss?fileID=7433441132597879392&amp;guid=dc3922656bcc222469152418c1839f87&amp;type=3#LBSOverrideStyle" />
    <ui:VisualElement name="VisualElement" style="flex-grow: 1; flex-direction: row; position: absolute; width: 100%; height: 100%; visibility: visible; opacity: 1; overflow: visible;">
        <ISILab.LBS.Plugin.UI.Editor.MainView focusable="true" name="MainView" tabindex="0" class="lbs-graph-view" style="flex-grow: 1; width: auto; height: auto; visibility: visible; display: flex; -unity-text-align: upper-left;">
            <ui:VisualElement name="HelpOverlayAnchor" style="flex-grow: 1; position: absolute; height: 26px; width: 30px; top: 32px; left: 72px;" />
        </ISILab.LBS.Plugin.UI.Editor.MainView>
    </ui:VisualElement>
    <ISILab.LBS.Plugin.UI.Editor.Windows.ToolBar.ToolBarMain name="ToolBar" style="height: 24px; border-bottom-color: rgb(36, 36, 36); border-bottom-width: 1px; max-height: 24px; min-height: 24px; -unity-background-scale-mode: scale-to-fit; flex-shrink: 0;" />
    <ISILab.Commons.VisualElements.Editor.SplitView picking-mode="Ignore" fixed-pane-index="1" fixed-pane-initial-dimension="400" name="SplitView" style="justify-content: space-around; align-self: stretch; flex-direction: row-reverse; flex-wrap: wrap; align-items: flex-end;">
        <ui:VisualElement picking-mode="Ignore" name="Workspace" style="flex-grow: 1; display: flex; flex-shrink: 1; align-self: stretch; justify-content: space-around; align-items: stretch; flex-wrap: nowrap;">
            <ISILab.LBS.Plugin.VisualElements.Editor.StaticTemplateComponents.StartedSign.LBSStartedSign name="NoLayerSign" style="position: absolute; right: 0; bottom: 0; top: 0; left: 0; align-items: center; justify-content: center;" />
            <ui:VisualElement picking-mode="Ignore" name="WorspaceOverlay" style="width: auto; min-width: auto; min-height: auto; flex-direction: row; padding-left: 5px; padding-right: 5px; padding-top: 5px; padding-bottom: 5px; flex-grow: 1;">
                <ui:VisualElement picking-mode="Ignore" style="flex-grow: 1; flex-direction: row; width: 406px; align-items: flex-start; border-left-width: 1px; border-right-width: 1px; border-top-width: 1px; border-bottom-width: 1px;">
                    <LBS.VisualElements.ToolKit name="Toolkit" style="flex-grow: 0; min-width: auto; flex-shrink: 1;" />
                </ui:VisualElement>
                <ui:VisualElement picking-mode="Ignore" name="FloatingPanelContent" style="flex-grow: 1; width: 350px; max-width: 350px; min-width: 350px; flex-shrink: 0; align-self: stretch; flex-direction: row-reverse; justify-content: flex-end;">
                    <ui:ScrollView scroll-deceleration-rate="0,135" elasticity="0.2" vertical-scroller-visibility="Hidden" horizontal-scroller-visibility="Hidden" name="SubPanelScrollView" picking-mode="Ignore" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); width: 350px; max-width: 350px; min-width: 350px; flex-shrink: 0;">
                        <ui:VisualElement name="ExtraPanel" picking-mode="Ignore" style="width: 350px; max-width: 350px; min-width: 350px; background-image: none; -unity-background-image-tint-color: rgba(0, 0, 0, 0); background-color: rgba(0, 0, 0, 0); padding-left: 0; padding-right: 0; padding-top: 0; padding-bottom: 0; flex-grow: 1;" />
                    </ui:ScrollView>
                </ui:VisualElement>
            </ui:VisualElement>
            <ISILab.LBS.Editor.Windows.LBSWaitTaskOverlay name="WaitOverlay" step="3" show-rect="false" style="position: absolute; flex-grow: 1; width: 100%; height: 100%; overflow: hidden;" />
        </ui:VisualElement>
        <ui:VisualElement picking-mode="Ignore" name="InspectorNExtrabar" style="width: auto; height: auto; overflow: hidden; position: relative; flex-direction: row-reverse; flex-wrap: nowrap; flex-shrink: 1; align-items: stretch; justify-content: flex-start; flex-grow: 0; visibility: visible; align-self: stretch; max-width: none; right: auto; left: 0; min-width: 50px;">
            <ui:VisualElement name="Inspector" class="lbs-inspector__show" style="transition-timing-function: linear; transition-duration: 0.12s;">
                <ISILab.LBS.VisualElements.LBSInspectorPanel name="InspectorPanel" />
                <ui:VisualElement name="HideBar" class="lbs-inspector-tabs" style="border-bottom-width: 1px; border-bottom-color: rgba(0, 0, 0, 0.2); border-right-width: 1px; border-right-color: rgba(0, 0, 0, 0.2); border-top-color: rgba(0, 0, 0, 0.2); border-left-color: rgba(0, 0, 0, 0.2); justify-content: flex-end; min-height: auto; height: 28px;">
                    <ui:VisualElement style="align-self: flex-start; justify-content: flex-start; align-items: stretch; -unity-background-scale-mode: scale-to-fit;">
                        <ui:Button display-tooltip-when-elided="true" name="ButtonDisplayInspector" style="border-left-color: rgba(255, 255, 255, 0); border-right-color: rgba(255, 255, 255, 0); border-top-color: rgba(255, 255, 255, 0); border-bottom-color: rgba(255, 255, 255, 0); border-left-width: 0; border-right-width: 0; border-top-width: 0; border-bottom-width: 0; background-image: resource(&apos;Icons/Vectorial/SideToolBar/Icon=InspectorArrowRight&apos;); max-width: 32px; min-width: 24px; min-height: 24px; background-color: rgba(88, 88, 88, 0); scale: 0.75 0.75; -unity-background-scale-mode: scale-to-fit;" />
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="UnusedTopBar" class="SubBackground lbs-title-label-container" style="flex-grow: 0; background-color: rgb(47, 47, 47); flex-shrink: 0; height: 32px; max-height: 32px; min-height: 32px; min-width: auto; align-self: stretch; justify-content: flex-start; flex-wrap: wrap-reverse; display: none; align-items: stretch;">
                    <ui:Toggle value="false" focusable="true" name="InfoButton" tooltip="AI Assistant" class="lbs-tool-button-toggle lbs-tab-button" style="flex-direction: row; height: 32px; display: flex; border-right-width: 1px; rotate: 0; width: 32px; border-top-right-radius: 4px; border-bottom-left-radius: 0; border-bottom-width: 0; margin-left: 12px;">
                        <ui:VisualElement name="Icon" class="lbs-default-icon" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); align-self: center; align-items: auto; background-image: resource(&apos;Icons/Vectorial/Icon=Log&apos;); -unity-background-image-tint-color: rgb(255, 255, 255);" />
                    </ui:Toggle>
                    <ui:Toggle value="false" focusable="true" name="ModuleButton" tooltip="AI Assistant" class="lbs-tool-button-toggle lbs-tab-button" style="flex-direction: row; height: 32px; display: flex; border-right-width: 1px; rotate: 0; width: 32px; border-top-right-radius: 4px; border-bottom-left-radius: 0; border-bottom-width: 0; margin-left: 3px;">
                        <ui:VisualElement name="Icon" class="lbs-default-icon" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); align-self: center; align-items: auto; background-image: resource(&apos;Icons/Vectorial/Module_Panel_Icon&apos;); -unity-background-image-tint-color: rgb(255, 255, 255);" />
                    </ui:Toggle>
                    <ui:Toggle value="false" focusable="true" name="AssistantTopButton" tooltip="AI Assistant" class="lbs-tool-button-toggle lbs-tab-button" style="flex-direction: row; height: 32px; display: flex; border-right-width: 1px; rotate: 0; width: 32px; border-top-right-radius: 4px; border-bottom-left-radius: 0; border-bottom-width: 0; margin-left: 3px;">
                        <ui:VisualElement name="Icon" class="lbs-default-icon" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); align-self: center; align-items: auto; background-image: resource(&apos;Icons/Vectorial/Exterior/Icon=AssitanceV2&apos;); -unity-background-image-tint-color: rgb(255, 255, 255);" />
                    </ui:Toggle>
                    <ui:Toggle value="false" focusable="true" name="TagButton" tooltip="AI Assistant" class="lbs-tool-button-toggle lbs-tab-button" style="flex-direction: row; height: 32px; display: flex; border-right-width: 1px; rotate: 0; width: 32px; border-top-right-radius: 4px; border-bottom-left-radius: 0; border-bottom-width: 0; margin-left: 24px;">
                        <ui:VisualElement name="Icon" class="lbs-default-icon" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); align-self: center; align-items: auto; background-image: resource(&apos;Icons/Vectorial/Icon=TagOutline&apos;); -unity-background-image-tint-color: rgb(255, 255, 255);" />
                    </ui:Toggle>
                    <ui:Toggle value="false" focusable="true" name="BundleButton" tooltip="AI Assistant" class="lbs-tool-button-toggle lbs-tab-button" style="flex-direction: row; height: 32px; display: flex; border-right-width: 1px; rotate: 0; width: 32px; border-top-right-radius: 4px; border-bottom-left-radius: 0; border-bottom-width: 0; margin-left: 3px;">
                        <ui:VisualElement name="Icon" class="lbs-default-icon" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); align-self: center; align-items: auto; background-image: resource(&apos;Icons/Vectorial/UpperToolBar/Icon=BundleIcon&apos;); -unity-background-image-tint-color: rgb(255, 255, 255);" />
                    </ui:Toggle>
                    <ui:VisualElement name="VisualElement" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); flex-direction: row-reverse; min-height: auto; min-width: auto; align-self: stretch; justify-content: space-between; align-items: auto; flex-wrap: nowrap; height: 32px;">
                        <ui:Toggle value="false" focusable="true" name="HideButton" tooltip="AI Assistant" class="lbs-tool-button-toggle lbs-tab-button" style="flex-direction: row; height: 24px; display: flex; border-right-width: 0; rotate: 0; width: 24px; border-top-right-radius: 0; border-bottom-left-radius: 0; border-bottom-width: 0; margin-left: 0; border-left-width: 0; border-top-width: 0; justify-content: space-around; align-self: center; flex-wrap: nowrap; margin-right: 0; margin-top: 0; margin-bottom: 0; border-top-left-radius: 0; border-bottom-right-radius: 0; padding-left: 0; padding-right: 0; padding-top: 0; padding-bottom: 0;">
                            <ui:VisualElement name="Icon" class="lbs-default-icon" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); align-self: center; align-items: auto; background-image: resource(&apos;Icons/Vectorial/SideToolBar/Icon=InspectorArrowRight&apos;); -unity-background-image-tint-color: rgb(255, 255, 255); height: 24px; -unity-background-scale-mode: scale-to-fit;" />
                        </ui:Toggle>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ISILab.LBS.Plugin.UI.Editor.Panel.LBSSideBarPanel />
        </ui:VisualElement>
    </ISILab.Commons.VisualElements.Editor.SplitView>
    <ISILab.LBS.Plugin.UI.Editor.Panel.InfoToolbar name="InfoToolbar" style="flex-shrink: 0;" />
</ui:UXML>
