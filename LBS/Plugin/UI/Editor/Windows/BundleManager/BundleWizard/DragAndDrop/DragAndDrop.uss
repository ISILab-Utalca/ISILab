.background {
    flex-grow: 1;
    /*background-color: var(--lbs-default-base-solid-gray-color);*/
}

.drop-area {
    flex-grow: 1;
    align-items: center;
    justify-content: center;
    margin-left: 10px;
    margin-right: 10px;
    margin-top: 10px;
    margin-bottom: 10px;
    padding-left: 5px;
    padding-right: 5px;
    padding-top: 5px;
    padding-bottom: 5px;
    background-color: var(--lbs-dark-purple-color);
    border-left-color: var(--lbs-default-white-overlay-color);
    border-right-color: var(--lbs-default-white-overlay-color);
    border-top-color: var(--lbs-default-white-overlay-color);
    border-bottom-color: var(--lbs-default-white-overlay-color);
    border-left-width: var(--lbs-default-frame-border-radius);
    border-right-width: var(--lbs-default-frame-border-radius);
    border-top-width: var(--lbs-default-frame-border-radius);
    border-bottom-width: var(--lbs-default-frame-border-radius);
    border-top-left-radius: 20px;
    border-bottom-left-radius: 20px;
    border-top-right-radius: 20px;
    border-bottom-right-radius: 20px;
    
    /* Asegura que el Label absoluto se posicione respecto a este panel */
    position: relative;
}

.drop-area--dropping {
    opacity: 0.5;
    background-color: var(--lbs-selection-dark-green-color);
}

.drop-area__label {
    -unity-font-style: italic;
    color: var(--lbs-text-color);


    /* Saca al texto del cßlculo de tama˝o del panel */

    /* Centra el texto visualmente sin empujar los bordes */
    -unity-text-align: middle-center;
}
