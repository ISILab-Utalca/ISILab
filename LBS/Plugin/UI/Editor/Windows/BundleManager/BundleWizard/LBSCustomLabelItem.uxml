<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="Background" style="flex-grow: 1; flex-direction: row; align-self: auto; align-content: stretch; justify-content: space-between; align-items: auto; width: 100%; height: 32px; min-width: 200px; border-top-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-left-width: 1px; border-left-color: rgba(255, 255, 255, 0.24); border-right-color: rgba(255, 255, 255, 0.24); border-top-color: rgba(255, 255, 255, 0.24); border-bottom-color: rgba(255, 255, 255, 0.24); margin-top: 0; overflow: hidden;">
        <ui:VisualElement name="tabElement" style="-unity-background-scale-mode: stretch-to-fill; padding-top: 0; padding-bottom: 0; margin-left: 0; border-right-width: 1px; border-left-color: rgba(255, 255, 255, 0.24); border-right-color: rgba(255, 255, 255, 0.24); border-top-color: rgba(255, 255, 255, 0.24); border-bottom-color: rgba(255, 255, 255, 0.24); border-left-width: 0; align-self: stretch;">
            <ISILab.LBS.CustomComponents.LBSCustomLabel text="&#x9;" name="textTab" />
        </ui:VisualElement>
        <ISILab.LBS.CustomComponents.LBSCustomLabel text="TextL" name="textL" style="flex-shrink: 1; flex-grow: 1; flex-direction: row; align-self: center; align-content: auto; margin-top: 2px; margin-right: 0; margin-bottom: 2px; margin-left: 0; padding-top: 4px; padding-right: 4px; padding-bottom: 4px; padding-left: 4px; align-items: auto; justify-content: flex-start;" />
        <ISILab.LBS.CustomComponents.LBSCustomLabel text="TextR" name="textR" style="flex-shrink: 1; flex-grow: 1; flex-direction: row; align-self: center; align-content: stretch; margin-top: 2px; margin-right: 0; margin-bottom: 2px; margin-left: 0; padding-top: 4px; padding-right: 4px; padding-bottom: 4px; padding-left: 4px; -unity-text-align: middle-right;" />
    </ui:VisualElement>
</ui:UXML>
