:root {
    --lbs-light-red-color: rgb(254, 118, 105);
    --lbs-selection-dark-red-color: rgb(200, 92, 82);
    
    --lbs-light-green-color: rgb(194, 246, 100);
    --lbs-selection-dark-green-color: rgb(118, 151, 67);
    
    --lbs-light-yellow-color: rgb(247, 196, 64);
    --lbs-darker-selection-yellow-color: rgb(255, 142, 0);
    
    --lbs-light-blue-color: rgb(135, 215, 246);
    --lbs-selection-dark-teal-color: rgb(98, 139, 200);
    
    --lbs-light-purple-color: rgb(163, 160, 251);

    --lbs-default-icon-color: rgb(210,210,210);
    --lbs-default-text-color: rgb(220,220,220);
    
    --lbs-default-base-solid-gray-color: rgb(60, 60, 60);
    --lbs-default-field-solid-bg-gray-color: rgb(40,40,40);
    --lbs-default-darker-solid-gray-color: rgb(33, 33, 33);
    --lbs-default-unity-6-black-color: rgb(20,20,20);

    --lbs-default-selectable-gray-color: rgb(72,72,72);
    --lbs-default-selectable-hover-color: rgb(88,88,88);
    
    --lbs-default-white-overlay-color: rgba(255, 255, 255, 0.2);
    --lbs-default-dark-overlay-color: rgba(0, 0, 0, 0.2);
    
    --lbs-selection-neutral-blue-color: rgb(54, 123, 245);
    --lbs-selection-focus-blue-color: rgb(44,93,135);
    --lbs-selection-dark-blue-color: rgb(24, 55, 110);
    
    --lbs-quest-teal-color: rgb(0,255,174);
    --lbs-quest-rose-color: rgb(207,32,80);
    --lbs-quest-purple-color: rgb(151,71,255);

    --lbs-default-frame-border-radius: 3px
}

.dark {
    --lbs-icon-color: rgb(210,210,210);
    --lbs-text-color: rgb(220,220,220);
    
    --lbs-base-solid-gray-color: rgb(60, 60, 60);
    --lbs-field-solid-bg-gray-color: rgb(40,40,40);
    --lbs-darker-solid-gray-color: rgb(33, 33, 33);
    --lbs-unity-6-black-color: rgb(20,20,20);

    --lbs-selectable-gray-color: rgb(72,72,72);
    --lbs-selectable-hover-color: rgb(88,88,88);

    --lbs-white-overlay-color: var(--lbs-default-white-overlay-color);
    --lbs-dark-overlay-color: var(--lbs-default-dark-overlay-color);

    --graph-thin-line-color: rgba(196, 196, 196, 0.02);
    --graph-thick-line-color: rgba(196, 196, 196, 0.1);

    --lbs-selection-neutral-blue-color: rgb(54, 123, 245);
    --lbs-selection-dark-blue-color: rgb(31, 90, 194);

    --lbs-main-blue-color: var(--lbs-selection-neutral-blue-color);
    --lbs-main-yellow-color: var(--lbs-light-yellow-color);
    --lbs-main-green-color: var(--lbs-light-green-color);
    
}

.alt {
    --lbs-icon-color: rgb(173,185,215);
    --lbs-text-color: rgb(220,220,220);
    
    --lbs-base-solid-gray-color: rgb(40,44,52);
    --lbs-field-solid-bg-gray-color: rgb(22,26,30);
    --lbs-darker-solid-gray-color: rgb(21, 24, 28);
    --lbs-unity-6-black-color: rgb(10,13,15);

    --lbs-selectable-gray-color: rgb(42,48,60);
    --lbs-selectable-hover-color: rgb(80,88,108);

    --lbs-white-overlay-color: var(--lbs-default-white-overlay-color);
    --lbs-dark-overlay-color: var(--lbs-default-dark-overlay-color);

    --graph-thin-line-color: rgba(196, 202, 208, 0.02);
    --graph-thick-line-color: rgba(196, 202, 208, 0.1);

    --lbs-selection-neutral-blue-color: rgb(54, 123, 245);
    --lbs-selection-dark-blue-color: rgb(31, 90, 194);

    --lbs-main-blue-color: var(--lbs-selection-neutral-blue-color);
    --lbs-main-yellow-color: var(--lbs-light-yellow-color);
    --lbs-main-green-color: var(--lbs-light-green-color);
}

.light {
    --lbs-icon-color: rgb(40,40,40);
    --lbs-text-color: rgb(20,20,20);
    
    --lbs-base-solid-gray-color: rgb(217, 217, 217);
    --lbs-field-solid-bg-gray-color: rgb(174,174,174);
    --lbs-darker-solid-gray-color: rgb(150,150, 150);
    --lbs-unity-6-black-color: rgb(240,240,240);

    --lbs-selectable-gray-color: rgb(227,227,227);
    --lbs-selectable-hover-color: rgb(196,196,196);

    --graph-thin-line-color: rgba(20, 20, 20, 0.02);
    --graph-thick-line-color: rgba(20, 20, 20, 0.1);

    /*invert default color*/
    --lbs-white-overlay-color: var(--lbs-default-dark-overlay-color);
    --lbs-dark-overlay-color: var(--lbs-default-white-overlay-color);
    
    --lbs-selection-neutral-blue-color: rgb(54, 123, 245);
    --lbs-selection-dark-blue-color: rgb(54, 123, 245);

    --lbs-main-blue-color: var(--lbs-selection-dark-blue-color);
    --lbs-main-yellow-color: var(--lbs-default-icon-color);
    --lbs-main-green-color: var(--lbs-selection-dark-green-color);
    
}

.darker {
    --lbs-icon-color: rgb(210,210,210);
    --lbs-text-color: rgb(220,220,220);

    --lbs-base-solid-gray-color: rgb(22,22,24);
    --lbs-field-solid-bg-gray-color: rgb(12,12,12);
    --lbs-darker-solid-gray-color: rgb(15,17,20);
    --lbs-unity-6-black-color: rgb(10,13,15);

    --lbs-selectable-gray-color: rgb(30,31,32);
    --lbs-selectable-hover-color: rgb(54,55,56);
    --lbs-selectable-boder-color: rgba(255, 255, 255, 1);

    --lbs-white-overlay-color: rgba(255, 255, 255, 0.4);
    --lbs-dark-overlay-color: rgba(255, 255, 255, 0.1);
    
    --graph-thin-line-color: rgba(196, 202, 208, 0.02);
    --graph-thick-line-color: rgba(196, 202, 208, 0.1);

    --lbs-selection-neutral-blue-color: rgb(54, 123, 245);
    --lbs-selection-dark-blue-color: rgb(31, 90, 194);

    --lbs-main-blue-color: var(--lbs-selection-neutral-blue-color);
    --lbs-main-yellow-color: var(--lbs-light-yellow-color);
    --lbs-main-green-color: var(--lbs-light-green-color);
    
    --lbs-frame-border-radius: 0px;
}


/*useful styles for general cases*/


.horizontal{
    --height: 24px;
    --width: 100%;
    flex-direction: row;
}

.vertical{
    --height: 100%;
    --width: 24px;
    flex-direction: column;
}