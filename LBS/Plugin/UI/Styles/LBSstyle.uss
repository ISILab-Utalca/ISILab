    border-radius: 4px;
    margin: 2px;
    padding: 4px;
}

.lbs-quest-action-icon {
    -unity-background-image-tint-color: var(--lbs-light-blue-color);
}

.lbs-nodeDataPanel {
    flex-grow: 0;
    border-left-color: rgb(32, 32, 32);
    border-right-color: rgb(32, 32, 32);
    border-top-color: rgb(32, 32, 32);
    border-bottom-color: rgb(32, 32, 32);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    padding-top: 2px;
    padding-right: 2px;
    padding-bottom: 2px;
    padding-left: 2px;
    margin-top: 1px;
    margin-right: 1px;
    margin-bottom: 1px;
    margin-left: 1px;
}

.lbs_node {
}

.lbs-vertical-divider {
    height: 1px;
    margin-bottom: 3px;
    min-height: 1px;
    max-height: 1px;
    background-color: rgba(255, 255, 255, 0.3);
    margin-left: 2px;
    margin-right: 2px;
    margin-top: 3px;
}

.lbs-horizontal-divider {
    height: 3px;
    margin-bottom: 3px;
    background-color: var(--lbs-white-overlay-color, var(--lbs-default-white-overlay-color));
    border-width: 1px 0 1px 0;
    border-color: var(--lbs-dark-overlay-color, var(--lbs-default-dark-overlay-color));
}

.lbs-panel {
    padding-left: 2px;
    padding-top: 2px;
    padding-right: 2px;
    padding-bottom: 2px;
    background-color: var(--lbs-base-solid-gray-color);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-left-color: rgba(0, 0, 0, 0.3);
    border-right-color: rgba(0, 0, 0, 0.3);
    border-bottom-color: rgba(0, 0, 0, 0.3);
    border-top-color: rgba(0, 0, 0, 0.3);
}

.lbs-base-panel {
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    border-color: var(--lbs-dark-overlay-color, var(--lbs-default-dark-overlay-color));
    border-width: 1px;
}

.lbs-background-panel {
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-left-color: rgba(0, 0, 0, 0.2);
    border-right-color: rgba(0, 0, 0, 0.2);
    border-top-color: rgba(0, 0, 0, 0.2);
    border-bottom-color: rgba(0, 0, 0, 0.2);
}

.lbs-foldout {
    border-left-color: rgba(0, 0, 0, 0.55);
    border-right-color: rgba(0, 0, 0, 0.55);
    border-top-color: rgba(0, 0, 0, 0.55);
    border-bottom-color: rgba(0, 0, 0, 0.55);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
}

.lbs-foldout__toggle {
    padding-top: 2px;
    padding-bottom: 2px;
    padding-right: 2px;
    padding-left: 2px;
    justify-content: center;
    align-items: center;
    align-self: auto;
    align-content: center;
}

.lbs-foldout-menu-button {
    height: 16px;
    width: 16px;
    position: relative;
    right: 0;
    left: auto;
    flex-direction: row;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.1);
    border-top-left-radius: 2px;
    border-top-right-radius: 2px;
    border-bottom-right-radius: 2px;
    border-bottom-left-radius: 2px;
}

.lbs-foldout-panel {
    padding-left: 2px;
    padding-top: 2px;
    padding-right: 2px;
    padding-bottom: 2px;
    background-color: var(--lbs-base-solid-gray-color);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-left-color: rgba(0, 0, 0, 0.3);
    border-right-color: rgba(0, 0, 0, 0.3);
    border-bottom-color: rgba(0, 0, 0, 0.3);
    border-top-color: rgba(0, 0, 0, 0.3);
}

.lbs-custom-foldout-checkmark {
}

.lbs-custom-progress-bar {
    padding-top: 2px;
    padding-right: 1px;
    padding-bottom: 1px;
    padding-left: 1px;
    margin-top: 0;
    margin-left: 0;
    margin-right: 0;
    margin-bottom: 0;
}

.lbs-custom-progress-bar__progress {
    border-left-color: rgba(255, 255, 255, 0.2);
    border-right-color: rgba(255, 255, 255, 0.2);
    border-top-color: rgba(255, 255, 255, 0.2);
    border-bottom-color: rgba(255, 255, 255, 0.2);
    display: flex;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
}

.lbs-custom-progress-bar__container {
    flex-grow: 1;
}

.lbs-custom-progress-bar__background {
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
}

.lbs-slide-toggle {
    flex-direction: row;
    margin-top: 2px;
    margin-right: 0;
    margin-bottom: 2px;
    margin-left: 0;
    padding: 4px;
    justify-content: space-between;
    align-items: center;
}

.lbs-slide-toggle > Label {
    flex-grow: 1;
}


.lbs-slide-toggle__input {
    background-color: var(--lbs-unity-6-black-color);
    max-width: 32px;
    max-height: 24px;
    height: 18px;
    border-radius: 4px;
    overflow: visible;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-right-color: var(--lbs-darker-solid-gray-color);
    border-top-color: var(--lbs-darker-solid-gray-color);
    border-bottom-color: var(--lbs-darker-solid-gray-color);
    border-left-color: var(--lbs-darker-solid-gray-color);
    margin-top: 10px;
    transition-property: background-color;
    transition-duration: 0.2s;
}

.lbs-slide-toggle__input-knob {
    height: 16px;
    width: 20px;
    background-color: var(--lbs-selectable-gray-color);
    position: absolute;
    border-top-left-radius: 3px;
    border-bottom-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    top: 0;
    transition-property: translate, background-color;
    transition-duration: 0.2s, 0.2s;
    translate: 0 0;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: var(--lbs-dark-overlay-color);
    border-right-color: var(--lbs-dark-overlay-color);
    border-top-color: var(--lbs-dark-overlay-color);
    border-bottom-color: var(--lbs-dark-overlay-color);
}

.lbs-slide-toggle__input-checked > .lbs-slide-toggle__input-knob {
    translate: 10px 0;
    background-color: var(--lbs-light-green-color);
}

.lbs-toolbar {
    border-width: 1px 1px 1px 1px;
    border-color: var(--lbs-dark-overlay-color, var(--lbs-default-dark-overlay-color));
    height: var(--height);
    width: var(--width);
}

.lbs-toolbar-toggle {
    border-width: 1px 1px 1px 1px;
    border-color: var(--lbs-dark-overlay-color);
    background-color: var(--lbs-base-solid-gray-color);
    align-items: center;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
    padding-top: 0;
    padding-right: 4px;
    padding-bottom: 0;
    padding-left: 4px;
    align-self: stretch;
    justify-content: center;
    flex-direction: row;
}

.lbs-toolbar-toggle:hover {
    background-color: var(--lbs-selectable-hover-color, var(--lbs-default-selectable-hover-color));
    /*scale: 1.15 1.15;*/
    transition-duration: 0.2s;
    transition-timing-function: ease-in-out;
}

.lbs-toolbar-toggle:selected {
    background-color: var(--lbs-selection-neutral-blue-color);
    scale: 1 1;
    transition-timing-function: ease-in-out;
    transition-duration: 0.2s;
}

.lbs-toolbar-menu {
    border-width: 1px 1px 1px 1px;
    border-color: var(--lbs-dark-overlay-color);
    background-color: var(--lbs-base-solid-gray-color);
    border-bottom-color: var(--lbs-dark-overlay-color);
    border-top-color: var(--lbs-dark-overlay-color);
    border-left-color: var(--lbs-dark-overlay-color);
    border-right-color: var(--lbs-dark-overlay-color);
    flex-direction: row;
    padding-left: 4px;
    padding-right: 4px;
    align-content: center;
    align-items: center;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
}

.lbs-toolbar-menu:hover {
    background-color: var(--lbs-selectable-hover-color);
}

.lbs-toolbar-menu:active {
    background-color: var(--lbs-selection-dark-blue-color);
}

.lbs-toolbar-button {
    border-color: var(--lbs-dark-overlay-color, var(--lbs-default-dark-overlay-color));
    border-width: 1px 1px 1px 1px;
    flex-direction: row;
    padding-left: 4px;
    padding-right: 4px;
    align-content: center;
    align-items: center;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
}

.normal-color{
    background-color: var(--lbs-base-solid-gray-color);
}

.normal-color:hover {
    background-color: var(--lbs-selectable-hover-color, var(--lbs-default-selectable-hover-color));
}

.normal-color:active {
    background-color: var(--lbs-selection-dark-blue-color);
}

.alert-color{
    background-color: var(--lbs-default-background-container-red-color);
}

.alert-color:hover {
    background-color: var(--lbs-default-neutral-red-color);
}

.alert-color:active {
    background-color: var(--lbs-default-hightlight-red-color);
}


.lbs-window {
    flex-grow: 1;
    margin-top: 2px;
    margin-right: 2px;
    margin-bottom: 2px;
    margin-left: 2px;
    padding-top: 8px;
    padding-bottom: 4px;
    padding-right: 4px;
    padding-left: 4px;
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-radius: 6px;
    border-left-color: var(--lbs-dark-overlay-color);
    border-right-color: var(--lbs-dark-overlay-color);
    border-top-color: var(--lbs-dark-overlay-color);
    border-bottom-color: var(--lbs-dark-overlay-color);
}

.lbs-container-bg {
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    border-color: var(--lbs-dark-overlay-color, var(--lbs-default-dark-overlay-color));
    border-width: 1px;
}

.lbs-box-container {
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    border-width: 1px;
    border-radius: 1.5px;
    border-color: var(--lbs-dark-overlay-color);
    margin: 2px;
    padding: 1px;
}

.lbs-field-box-container {
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    border-width: 1px;
    border-radius: 1.5px;
    border-color: var(--lbs-dark-overlay-color);
    margin: 1px;
    padding: 3px;
}

.lbs-base-field-container {
    background-color: var(--lbs-field-solid-bg-gray-color, var(--lbs-default-field-solid-bg-gray-color));
    border-width: 1px;
    border-radius: 3px;
    border-color: var(--lbs-dark-overlay-color);
    margin: 1px;
    padding: 3px;
}

.lbs-title-label-container {
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 1px;
    border-bottom-color: var(--lbs-dark-overlay-color);
    margin-top: 0;
    margin-bottom: 0;
    height: 24px;
    min-height: 24px;
    max-height: 24px;
    padding-bottom: 2px;
    flex-direction: row;
}

.lbs-group-box {
    background-color: var(--lbs-dark-overlay-color, var(--lbs-default-dark-overlay-color));
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-radius: 1.5px;
    border-color: var(--lbs-dark-overlay-color, var(--lbs-default-dark-overlay-color));
    margin-right: 0;
    margin-top: 2px;
    margin-bottom: 2px;
    padding-left: 1px;
    padding-right: 1px;
    padding-top: 1px;
    padding-bottom: 1px;
    margin-left: 0;
}

.lbs-default-container-panel {
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    border-color: var(--lbs-dark-overlay-color, var(--lbs-default-dark-overlay-color));
    border-width: 1px;
    border-radius: 0;
    padding: 3px;
    margin-bottom: 6px;
}

.lbs-arrow {
    background-image: resource('Icons/Arrows/Icon=ArrowDown');
    flex-grow: 1;
    -unity-background-scale-mode: scale-to-fit;
    background-position-x: right 0;
    -unity-background-image-tint-color: var(--lbs-icon-color, var(--lbs-default-icon-color));
    height: 16px;
    width: 16px;
}

.lbs-dropdown-field {
}

.lbs-text-field {
}

.lbs-text-field > TextInput {
    border-color: var(--lbs-dark-overlay-color);
    border-width: 1px;
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    flex-grow: 1;
    align-self: stretch;
}

.lbs-vector2-field {
}

.lbs-vector2-field FloatInput {
    border-color: var(--lbs-dark-overlay-color);
    border-width: 1px;
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    flex-grow: 1;
    align-self: stretch;
    min-width: 32px;
    flex-shrink: 1;
}

.lbs-vector2-field > VisualElement {
    flex-grow: 1;
    align-self: stretch;
    flex-shrink: 1;
    align-items: stretch;
    flex-direction: column;
    height: 100%;
    width: auto;
}

.lbs-vector2-field .unity-composite-field__field-spacer {
    flex-grow: 1;
    flex-shrink: 1;
    align-self: stretch;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
    padding-top: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-left: 0;
}

.lbs-vector3-field FloatInput {
    border-color: var(--lbs-dark-overlay-color);
    border-width: 1px;
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    flex-grow: 1;
    align-self: stretch;
    min-width: 32px;
    flex-shrink: 1;
}

.lbs-vector3-field > VisualElement {
    flex-grow: 1;
    align-self: stretch;
    flex-shrink: 1;
    align-items: stretch;
    flex-direction: column;
    height: 100%;
    width: auto;
}

.lbs-object-field {
}

.lbs-graph-view {
}

.lbs-header-card {
    flex-direction: row;
    background-color: var(--lbs-base-solid-gray-color, var(--lbs-default-base-solid-gray-color));
    border-width: 1px;
    border-radius: 3px;
    margin-bottom: 4px;
    overflow: hidden;
    margin-top: 2px;
    margin-right: 2px;
    margin-left: 2px;
    border-top-color: var(--lbs-darker-solid-gray-color, var(--lbs-default-darker-solid-gray-color));
    border-right-color: var(--lbs-darker-solid-gray-color, var(--lbs-default-darker-solid-gray-color));
    border-bottom-color: var(--lbs-darker-solid-gray-color, var(--lbs-default-darker-solid-gray-color));
    border-left-color: var(--lbs-darker-solid-gray-color, var(--lbs-default-darker-solid-gray-color));
    min-height: 24px;
}

.lbs-button-tint-overlay {
    flex-grow: 1;
    width: 100%;
    height: 100%;
    position: absolute;
    opacity: 1;
}

.lbs-tree-view {
    flex-grow: 1;
    height: 18px;
    overflow: shown;
    padding: 10px;
}

.lbs-tree-view-item {
    flex-grow: 1;
    height: 18px;
    overflow: shown;
    padding: 10px;
}

.lbs-breadcrumbs {
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-left-color: rgb(22, 22, 22);
    border-right-color: rgb(22, 22, 22);
    border-top-color: rgb(22, 22, 22);
    border-bottom-color: rgb(22, 22, 22);
    background-color: rgb(62, 62, 62);
    border-radius: 1.5px;
}

.lbs-breadcrumb-item-selected {
    -unity-background-image-tint-color: rgb(152, 139, 248);
    background-image: none;
}

.lbs-tab-view {
}

.lbs-tab-view > .unity-tab-view__content-container {
    flex-grow: 1;
}

.lbs-tab {
}

.lbs-tab > .unity-tab__content-container {
    flex-grow: 1;
}

.lbs-custom-radio-button-group {
    flex-direction: column;
}

.lbs-wizard-menu-content {
    flex-grow: 1;
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
    padding: 32px;
}

.asset-grid-tile {
    flex-grow: 1;
    width: 100%;
    height: 100%;
}

.lbs-simple-palette {
}

.lbs-post-it {
    padding: 5 6 28 3;
    background-image: resource('Textures/post_it_v2_vector');
    background-size: cover;
    -unity-slice-left: 32;
    -unity-slice-top: 32;
    -unity-slice-right: 32;
    -unity-slice-bottom: 32;
    overflow: visible;
    flex-direction: column;
    padding-top: 11px;
    padding-right: 8px;
    padding-bottom: 39px;
    padding-left: 10px;
}

.lbs-post-it TextInput {
    background-color: transparent;
    border-color: transparent;
    overflow: visible;
}

.lbs-post-it TextField {
}

.lbs-post-it TextElement {
    color: rgb(58, 49, 37);
    -unity-text-align: upper-left;
    white-space: pre-wrap;
    flex-wrap: wrap;
    width: 100%;
    text-overflow: ellipsis;
}

.lbs-post-it > Label {
    -unity-text-align: upper-left;
    white-space: pre-wrap;
    flex-grow: 1;
    font-size: 12px;
    color: rgb(0, 0, 0);
}

.yellow-post-it {
    -unity-background-image-tint-color: rgb(255, 226, 153);
}

.green-post-it {
    -unity-background-image-tint-color: rgb(179, 239, 189);
}

.lbs-random-int-field {
}

.lbs-random-int-field TextField {
    flex-grow: 0.3;
}

.lbs-show-white-spaces {
    white-space: pre-wrap;
    /*white-space: nowrap;*/
    overflow: visible;
    -unity-text-overflow-position: start;
}

.lbs-custom-toggle > .unity-toggle__input{
    border-width: 1px;
    border-color:transparent;
}

.lbs-custom-toggle:hover > .unity-toggle__input{
    border-width: 1px;
    border-color: var(--lbs-light-purple-color);
    cursor: link;
}

.lbs-custom-toggle:checked > .unity-toggle__input > .unity-toggle__checkmark {
    background-image: url('project:/Assets/ISILab/Commons/Resources/Icons/Bundl_Interface/Characteristics_Boolean@32.png') !important;
}

.lbs-custom-toggle > .unity-toggle__input > .unity-toggle__checkmark {
    background-image: url('project:/Assets/ISILab/Commons/Resources/Icons/Bundl_Interface/Bundle_Individual_icon@32.png') !important;
}


.lbs-custom-dropdown-marginless {}

.lbs-custom-dropdown-marginless > VisualElement:last-child {
    margin-left: 0;
    margin-right: 0;
}

.lbs-button-only-tooltip-when-disabled {}

.lbs-button-only-tooltip-when-disabled:disabled:hover {
    background-color: var(--lbs-selectable-gray-color);
}

.lbs-custom-colored-icon {
    -unity-background-image-tint-color: var(--lbs-icon-color);
}

.lbs-custom-colored-icon-disabled {
    -unity-background-image-tint-color: var(--lbs-unselected-icon-color);
}

.lbs-custom-foldout #unity-content {
    flex-grow: 1;
}
