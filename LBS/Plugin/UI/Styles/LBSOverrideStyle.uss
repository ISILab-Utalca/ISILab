@import url("project://database/Assets/ISI%20Lab/LBS/Plugin/VisualElements/Styles/LBSStyleVariables.uss?fileID=7433441132597879392&guid=85a69280ec227ab48bb86c136d9591fe&type=3#LBSStyleVariables");


.unity-enum-field {
}

.unity-text-element {
    color: var(--lbs-text-color, var(--lbs-default-text-color));
}

.unity-enum-field__text {
    color: var(--lbs-text-color, var(--lbs-default-text-color));
}

.unity-enum-field__label {
    color: var(--lbs-text-color, var(--lbs-default-text-color));
}

.unity-enum-field__input {
    background-color: var(--lbs-field-solid-bg-gray-color, var(--lbs-default-field-solid-bg-gray-color));
}

.unity-base-field {
}

.unity-base-popup-field {
}

.unity-toolbar {
    background-color: var(--lbs-base-solid-gray-color);
    border-bottom-color: var(--lbs-dark-overlay-color);
    border-top-color: var(--lbs-dark-overlay-color);
    border-left-color: var(--lbs-dark-overlay-color);
    border-right-color: var(--lbs-dark-overlay-color);
}

.unity-button__image {
    -unity-background-image-tint-color:var(--lbs-icon-color, var(--lbs-default-icon-color));
}

.unity-image {
    -unity-background-image-tint-color: var(--lbs-icon-color, var(--lbs-default-icon-color));
}

ObjectFieldDisplay {
    border-color: var(--lbs-dark-overlay-color);
    border-width: 1px;
    background-color: var(--lbs-field-solid-bg-gray-color);
    flex-grow: 1;
    align-self: stretch;
    min-width: 32px;
    flex-shrink: 1;
}

.unity-collection-view__item--selected{
    background-color: var(--lbs-selection-neutral-blue-color)
}