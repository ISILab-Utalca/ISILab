        <ui:VisualElement class="lbs-group-box" style="flex-grow: 1;">
            <ISILab.LBS.CustomComponents.LBSCustomToggleField name="ShowConstraintToggle" label="Show Constraints" style="height: 32px;" />
        </ui:VisualElement>
    </ui:VisualElement>
    <ISILab.LBS.CustomComponents.LBSCustomFoldout text="Constraints" left-icon="project://database/Assets/ISILab/DevTools/Macros/PlaceholderUIVector.svg?fileID=7388822144124034973&amp;guid=5aa5737462342b24c866198641cdaf08&amp;type=3#PlaceholderUIVector" />
</ui:UXML>
