<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <Style src="project://database/Assets/ISILab/LBS/Plugin/UI/Styles/LBSstyle.uss?fileID=7433441132597879392&amp;guid=9614f5340894b3546b59d43b5f2be029&amp;type=3#LBSstyle" />
    <ui:VisualElement name="Border" picking-mode="Ignore" style="flex-direction: row; align-self: center; justify-content: space-evenly; align-items: flex-start; flex-grow: 1; background-color: rgb(56, 56, 56); flex-shrink: 1; max-width: none; padding-left: 2px; padding-right: 2px; padding-top: 2px; padding-bottom: 2px; margin-left: 2px; margin-right: 2px; margin-top: 2px; margin-bottom: 2px; max-height: none; min-height: auto; height: auto; min-width: auto; border-left-color: rgb(95, 95, 95); border-right-color: rgb(95, 95, 95); border-top-color: rgb(95, 95, 95); border-bottom-color: rgb(95, 95, 95); border-left-width: 1px; border-right-width: 1px; border-top-width: 1px; border-bottom-width: 1px; border-top-left-radius: 6px; border-bottom-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; -unity-text-align: middle-left; position: absolute; flex-wrap: wrap;">
        <ui:VisualElement name="Previous" style="flex-grow: 1; align-self: auto; justify-content: space-evenly; min-width: 75px;">
            <ui:Label text="Previous" style="-unity-text-align: middle-center;" />
            <ISILab.LBS.CustomComponents.LBSCustomButton button-tint="#585858FF" icon-image="project://database/Assets/ISILab/Commons/Resources/Icons/Vectorial/QuestIcons/Quest=Prev_Quest.svg?fileID=7388822144124034973&amp;guid=154cf402299c4144d95a7b5e4550ca11&amp;type=3#Quest=Prev_Quest" name="PreviousStep" tooltip="Go to previous step" class="lbs_ToolButton" style="color: rgb(88, 88, 88); background-color: rgb(88, 88, 88); border-left-color: rgb(48, 48, 48); border-right-color: rgb(48, 48, 48); border-top-color: rgb(48, 48, 48); border-bottom-color: rgb(36, 36, 36);" />
        </ui:VisualElement>
        <ui:VisualElement name="Ve" style="flex-grow: 1; align-self: stretch; justify-content: space-evenly; min-width: auto; padding-left: 10px; padding-right: 10px; margin-top: 2px; margin-right: 2px; margin-bottom: 2px; margin-left: 2px;">
            <ui:VisualElement name="StepType" style="flex-grow: 1; align-self: center; flex-shrink: 0; background-image: none; -unity-background-scale-mode: scale-to-fit; width: 32px; height: 32px;" />
            <ui:Label text="Action" name="Action" style="-unity-text-align: middle-center; align-self: center;" />
        </ui:VisualElement>
        <ui:VisualElement name="Next" style="flex-grow: 1; align-self: stretch; justify-content: space-evenly; min-width: 75px;">
            <ui:Label text="Next" style="-unity-text-align: middle-center;" />
            <ui:VisualElement name="NextContainer" style="flex-grow: 1;" />
            <ISILab.LBS.CustomComponents.LBSCustomButton button-tint="#585858FF" icon-image="project://database/Assets/ISILab/Commons/Resources/Icons/Vectorial/QuestIcons/Quest=Next_Quest.svg?fileID=7388822144124034973&amp;guid=f7a7e78297daae54d8533114b779de1f&amp;type=3#Quest=Next_Quest" name="NextStep" tooltip="Go to next step" class="lbs_ToolButton" style="color: rgb(88, 88, 88); background-color: rgb(88, 88, 88); border-left-color: rgb(48, 48, 48); border-right-color: rgb(48, 48, 48); border-top-color: rgb(48, 48, 48); border-bottom-color: rgb(36, 36, 36);" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
