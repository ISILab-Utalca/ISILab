<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <Style src="project://database/Assets/isi-lab-unity-module/LBS/Plugin/VisualElements/Styles/LBSstyle.uss?fileID=7433441132597879392&amp;guid=9614f5340894b3546b59d43b5f2be029&amp;type=3#LBSstyle" />
    <ISILab.LBS.CustomComponents.LBSCustomButton icon-image="project://database/Assets/isi-lab-unity-module/Commons/Assets2D/Resources/Icons/Vectorial/Icon=QuestAction.svg?fileID=7388822144124034973&amp;guid=8e6d54caf2a0f1548b7303b3800070ed&amp;type=3#Icon=QuestAction" text="Label" emoji-fallback-support="true" selectable="true" name="NewButton" enabled="true" icon-color="#87D7F6FF" />
    <ui:Button display-tooltip-when-elided="true" name="Button" class="lbs-action-button" style="flex-direction: row; align-items: center; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; border-top-left-radius: 0; border-top-right-radius: 0; border-bottom-right-radius: 0; border-bottom-left-radius: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-grow: 0; flex-shrink: 1;">
        <ui:VisualElement picking-mode="Ignore" name="Handle" class="lbs-icon lbs-item-content" style="flex-grow: 0; background-color: rgba(0, 0, 0, 0); background-image: resource(&apos;Icons/Vectorial/Artifact=ListHandle&apos;); flex-wrap: nowrap; flex-basis: auto; scale: 1 1; align-self: auto; justify-content: flex-start; align-items: flex-start; overflow: visible; -unity-slice-left: 0; -unity-slice-top: 0; -unity-slice-right: 0; -unity-slice-bottom: 0; -unity-slice-scale: 0; padding-right: 0; min-height: auto; max-height: none; height: 100%; border-top-width: 1px; border-right-width: 1px; border-bottom-width: 1px; background-size: contain; -unity-background-scale-mode: scale-to-fit;" />
        <ui:VisualElement picking-mode="Ignore" name="ActionIcon" class="lbs-quest-action-icon lbs-item-content" style="flex-grow: 0; background-color: rgba(0, 0, 0, 0); background-image: resource(&apos;Icons/Vectorial/Icon=QuestAction&apos;); flex-wrap: nowrap; -unity-background-scale-mode: scale-to-fit; flex-basis: auto; scale: 1 1; align-self: auto; justify-content: flex-start; align-items: flex-start; overflow: visible; -unity-slice-left: 0; -unity-slice-top: 0; -unity-slice-right: 0; -unity-slice-bottom: 0; -unity-slice-scale: 0; padding-right: 0; margin-right: -1px; min-width: 20px; max-width: 20px; min-height: 20px; background-position-y: center 0; background-size: contain;" />
        <ui:Label tabindex="-1" text="Label" display-tooltip-when-elided="true" name="Action" class="lbs-item-content" style="flex-grow: 1; flex-shrink: 1; flex-direction: row; align-items: flex-start; justify-content: flex-start; -unity-text-align: middle-left; padding-left: 6px; margin-left: 1px;" />
    </ui:Button>
