@import url("project://database/Assets/ISI%20Lab/LBS/Plugin/VisualElements/Styles/LBSStyleVariables.uss?fileID=7433441132597879392&guid=85a69280ec227ab48bb86c136d9591fe&type=3#LBSStyleVariables");

GridBackground {
    --grid-background-color: var(--lbs-field-solid-bg-gray-color);
    --line-color: var(--graph-thin-line-color);
    --thick-line-color: var(--graph-thick-line-color);
    --spacing: 10;
    flex-grow: 1;
}