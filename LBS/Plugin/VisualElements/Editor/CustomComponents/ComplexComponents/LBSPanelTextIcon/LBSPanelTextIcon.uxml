<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <ui:VisualElement name="Root" class="lbs-notificator" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); flex-direction: column; padding-left: 3px; padding-right: 3px; padding-top: 3px; padding-bottom: 3px; margin-top: 3px; justify-content: center; align-items: center; min-height: 24px;">
        <ui:Label tabindex="-1" text="Text" display-tooltip-when-elided="true" name="Label" style="font-size: 11px; padding-top: 3px; padding-bottom: 3px; padding-right: 3px; padding-left: 3px; white-space: normal; -unity-text-align: upper-center; align-self: center;" />
        <ui:VisualElement name="Icon" class="lbs-default-label-icon" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0); background-image: resource(&apos;Icons/Vectorial/Logo/LBS&apos;); -unity-background-image-tint-color: rgb(255, 255, 255); align-items: center; justify-content: space-around; align-self: center; height: 69px; width: 98px; max-height: 16px; min-height: 16px; -unity-background-scale-mode: scale-to-fit;" />
    </ui:VisualElement>
</ui:UXML>
