<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <Style src="project://database/Assets/isi-lab-unity-module/LBS/Plugin/VisualElements/Styles/LBSstyle.uss?fileID=7433441132597879392&amp;guid=9614f5340894b3546b59d43b5f2be029&amp;type=3#LBSstyle" />
    <engine:VisualElement name="Main_VE" style="width: 25px; height: 25px; min-width: 90%; min-height: 90%; max-width: 85%; max-height: 100%; align-self: center; align-items: center; justify-content: center; padding-top: 0%;">
        <engine:VisualElement name="Button_Container" style="flex-grow: 1; align-self: center; justify-content: center; align-content: center; align-items: center; margin-left: 3px; margin-right: 3px; margin-top: 3px; margin-bottom: 3px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-shrink: 0; width: 100%; height: 100%;">
            <engine:Button name="ColoredButton" style="align-self: auto; justify-content: flex-start; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-shrink: 0; border-top-left-radius: 0; border-top-right-radius: 0; border-bottom-right-radius: 0; border-bottom-left-radius: 0; border-left-color: rgb(255, 255, 255); border-right-color: rgb(255, 255, 255); border-top-color: rgb(255, 255, 255); border-bottom-color: rgb(255, 255, 255); background-color: rgb(255, 0, 0); position: absolute; align-content: auto; align-items: auto; flex-grow: 1; width: 100%; height: 100%;" />
            <engine:VisualElement name="Selector" enabled="true" style="flex-grow: 1; position: absolute; align-self: auto; align-content: auto; border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgb(59, 122, 255); border-right-color: rgb(59, 122, 255); border-top-color: rgb(59, 122, 255); border-bottom-color: rgb(59, 122, 255); align-items: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; width: 100%; height: 100%; flex-shrink: 0; display: flex; visibility: hidden;" />
        </engine:VisualElement>
    </engine:VisualElement>
</engine:UXML>
