<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <Style src="project://database/Assets/ISILab/LBS/Plugin/VisualElements/Styles/LBSstyle.uss?fileID=7433441132597879392&amp;guid=9614f5340894b3546b59d43b5f2be029&amp;type=3#LBSstyle" />
    <engine:VisualElement name="MainSample" style="flex-grow: 1; flex-shrink: 1; height: 100%; width: 100%; background-color: rgba(255, 69, 255, 0); align-items: auto; align-self: auto; justify-content: center; align-content: stretch; visibility: visible; overflow: visible; flex-direction: column;">
        <engine:VisualElement name="ColorMultiplier" style="flex-grow: 1; position: absolute; width: 100%; height: 100%; align-content: flex-start; justify-content: flex-start; align-items: stretch; align-self: auto; background-color: rgba(255, 0, 0, 0.39); display: flex; visibility: hidden;" />
        <engine:VisualElement name="TileBorder" style="flex-grow: 1; position: absolute; width: 100%; height: 100%; align-content: flex-start; justify-content: flex-start; align-items: stretch; align-self: auto; background-color: rgba(255, 0, 0, 0); border-top-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-left-width: 1px; border-left-color: rgba(255, 255, 255, 0.59); border-right-color: rgba(255, 255, 255, 0.59); border-top-color: rgba(255, 255, 255, 0.59); border-bottom-color: rgba(255, 255, 255, 0.59);" />
        <engine:VisualElement name="TileBorderHovered" style="flex-grow: 1; position: absolute; width: 100%; height: 100%; align-content: flex-start; justify-content: flex-start; align-items: stretch; align-self: auto; background-color: rgba(255, 0, 0, 0); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgb(0, 122, 255); border-right-color: rgb(0, 122, 255); border-top-color: rgb(0, 122, 255); border-bottom-color: rgb(0, 122, 255); display: flex; visibility: hidden;" />
        <ISILab.LBS.CustomComponents.LBSCustomButton name="InteractButton" selectable="false" focusable="true" style="align-self: center; width: 100%; height: 100%; margin-left: 0; margin-right: 0; margin-bottom: 0; margin-top: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-grow: 1; visibility: visible; background-color: rgba(0, 0, 0, 0); display: flex; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; border-left-color: rgba(0, 0, 0, 0); border-right-color: rgba(0, 0, 0, 0); border-top-color: rgba(0, 0, 0, 0); border-bottom-color: rgba(0, 0, 0, 0);" />
    </engine:VisualElement>
</engine:UXML>
