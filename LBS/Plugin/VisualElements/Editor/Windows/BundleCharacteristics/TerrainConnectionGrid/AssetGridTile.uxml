<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <Style src="project://database/Assets/isi-lab-unity-module/LBS/Plugin/VisualElements/Styles/LBSstyle.uss?fileID=7433441132597879392&amp;guid=9614f5340894b3546b59d43b5f2be029&amp;type=3#LBSstyle" />
    <engine:VisualElement name="MainSample" style="flex-grow: 0; flex-shrink: 0; height: 128px; width: 128px; background-color: rgb(255, 0, 255); bottom: 0; right: 0; top: auto; left: auto; align-items: flex-start; align-self: auto; justify-content: center; align-content: center;">
        <engine:VisualElement name="ColorMultiplier" style="flex-grow: 1; position: absolute; width: 100%; height: 100%; align-content: flex-start; justify-content: flex-start; align-items: stretch; align-self: auto; background-color: rgba(255, 0, 0, 0.78); display: flex;" />
        <engine:VisualElement name="TileBorder" style="flex-grow: 1; position: absolute; width: 100%; height: 100%; align-content: flex-start; justify-content: flex-start; align-items: stretch; align-self: auto; background-color: rgba(255, 0, 0, 0); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-left-color: rgba(255, 255, 255, 0.59); border-right-color: rgba(255, 255, 255, 0.59); border-top-color: rgba(255, 255, 255, 0.59); border-bottom-color: rgba(255, 255, 255, 0.59);" />
        <engine:VisualElement name="TileBorderHovered" style="flex-grow: 1; position: absolute; width: 100%; height: 100%; align-content: flex-start; justify-content: flex-start; align-items: stretch; align-self: auto; background-color: rgba(255, 0, 0, 0); border-top-width: 4px; border-right-width: 4px; border-bottom-width: 4px; border-left-width: 4px; border-left-color: rgb(0, 122, 255); border-right-color: rgb(0, 122, 255); border-top-color: rgb(0, 122, 255); border-bottom-color: rgb(0, 122, 255); display: flex;" />
    </engine:VisualElement>
</engine:UXML>
