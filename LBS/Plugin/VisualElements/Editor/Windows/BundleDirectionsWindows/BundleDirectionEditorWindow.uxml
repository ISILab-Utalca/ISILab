                </engine:VisualElement>
                <engine:VisualElement style="flex-grow: 0; position: absolute; top: 46px; left: -210px; height: 32px; width: 192px; bottom: auto; align-items: stretch;">
                    <ISILab.LBS.CustomComponents.LBSCustomDropdown name="LeftDirectionDropdown" label="Left" icon-image="project://database/Assets/ISI%20Lab/LBS/Plugin/VisualElements/Editor/Windows/BundleDirectionsWindows/ConnectionIcons/Type=Left.svg?fileID=7388822144124034973&amp;guid=f4706096a701f4f4092347cba6302330&amp;type=3#Type=Left" icon-position="Left" icon-color="#FFFFFFFF" enabled="true" class="lbs-field-box-container" />
                </engine:VisualElement>
                <engine:VisualElement style="flex-grow: 1; position: absolute; top: 46px; left: auto; height: 32px; width: 192px; bottom: auto; right: -207px; flex-shrink: 0;">
                    <ISILab.LBS.CustomComponents.LBSCustomDropdown name="RightDirectionDropdown" label="Right" icon-image="project://database/Assets/ISI%20Lab/LBS/Plugin/VisualElements/Editor/Windows/BundleDirectionsWindows/ConnectionIcons/Type=Right.svg?fileID=7388822144124034973&amp;guid=4d21b925e57f7464498d67f86cb416df&amp;type=3#Type=Right" icon-position="Left" enabled="true" class="lbs-field-box-container" />
                </engine:VisualElement>
                <engine:VisualElement name="VisualElement" style="flex-grow: 0; position: absolute; top: -29px; left: -200px; height: 32px; width: 192px; justify-content: flex-start; align-self: auto; align-content: flex-start; align-items: stretch; flex-shrink: 1; flex-direction: column;">
                    <ISILab.LBS.CustomComponents.LBSCustomDropdown name="ULDirectionDropdown" label="Upper Left" icon-image="project://database/Assets/ISI%20Lab/LBS/Plugin/VisualElements/Editor/Windows/BundleDirectionsWindows/ConnectionIcons/Type=TopLeft.svg?fileID=7388822144124034973&amp;guid=2fe8632374e01f54fbbc6092b2dc2420&amp;type=3#Type=TopLeft" icon-position="Left" enabled="true" class="lbs-field-box-container" />
                </engine:VisualElement>
                <engine:VisualElement name="VisualElement" style="flex-grow: 0; position: absolute; top: -29px; left: auto; height: 32px; width: 192px; justify-content: flex-start; align-self: auto; align-content: flex-start; align-items: stretch; flex-shrink: 1; flex-direction: column; right: -200px;">
                    <ISILab.LBS.CustomComponents.LBSCustomDropdown name="URDirectionDropdown" label="Upper Right" icon-image="project://database/Assets/ISI%20Lab/LBS/Plugin/VisualElements/Editor/Windows/BundleDirectionsWindows/ConnectionIcons/Type=TopRight.svg?fileID=7388822144124034973&amp;guid=8b1d16474221f9147886962fe1962196&amp;type=3#Type=TopRight" icon-position="Left" enabled="true" class="lbs-field-box-container" />
                </engine:VisualElement>
                <engine:VisualElement name="VisualElement" style="flex-grow: 0; position: absolute; top: auto; left: auto; height: 32px; width: 192px; bottom: -29px; align-items: stretch; right: -200px;">
