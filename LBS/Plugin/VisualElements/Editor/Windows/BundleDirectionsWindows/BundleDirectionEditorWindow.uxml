            <engine:VisualElement style="flex-grow: 0; flex-shrink: 0; position: absolute; bottom: 3px; left: 3px; width: 48px; height: 48px; background-image: url(&quot;project://database/Assets/ISI%20Lab/LBS/Plugin/VisualElements/Editor/Windows/BundleDirectionsWindows/ConnectionIcons/gizmo_zx.svg?fileID=7388822144124034973&amp;guid=b9ae400ed6aad054ebea53ab1603f838&amp;type=3#gizmo_zx&quot;);" />
        </engine:VisualElement>
        <engine:VisualElement name="LowerBar" class="lbs-box-container" style="flex-grow: 0; height: 32px; flex-direction: row-reverse;">
            <ISILab.LBS.CustomComponents.LBSCustomButton text="Save" name="SaveButton" style="flex-grow: 0; flex-shrink: 0; width: 72px;" />
            <ISILab.LBS.CustomComponents.LBSCustomButton text="Revert" name="RevertButton" style="flex-grow: 0; width: 64px;" />
            <ISILab.LBS.CustomComponents.LBSCustomUnsignedIntegerField name="ZoomScaleInt" label="Zoom FOV" max-length="100" value="5" class="lbs-field-box-container" style="width: 260px; position: absolute; right: 4px; top: -41px;" />
        </engine:VisualElement>
    </engine:VisualElement>
</engine:UXML>
