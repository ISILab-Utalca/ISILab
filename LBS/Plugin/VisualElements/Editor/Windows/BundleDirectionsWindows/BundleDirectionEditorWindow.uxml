                </engine:VisualElement>
                <engine:VisualElement name="VisualElement" style="flex-grow: 0; position: absolute; top: auto; left: -200px; height: 32px; width: 192px; bottom: -29px; align-items: stretch; right: auto;">
                    <ISILab.LBS.CustomComponents.LBSCustomDropdown name="LLDirectionDropdown" label="Lower Left&#10;" icon-image="project://database/Assets/ISI%20Lab/LBS/Plugin/VisualElements/Editor/Windows/BundleDirectionsWindows/ConnectionIcons/Type=BottomLeft.svg?fileID=7388822144124034973&amp;guid=42b9aed2038113f41812967a914872af&amp;type=3#Type=BottomLeft" icon-position="Left" class="lbs-field-box-container" />
                </engine:VisualElement>
