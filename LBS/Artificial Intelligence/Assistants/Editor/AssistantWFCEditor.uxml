<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <Style src="project://database/Assets//LBS/Plugin/VisualElements/Styles/LBSstyle.uss?fileID=7433441132597879392&amp;guid=9614f5340894b3546b59d43b5f2be029&amp;type=3#LBSstyle" />
    <ui:VisualElement name="VisualElement" class="dark" style="flex-grow: 1; flex-direction: column; height: auto; width: auto; align-items: center; align-self: stretch; margin-left: 0; margin-right: 0; justify-content: flex-start; align-content: flex-start;">
        <ui:Label text="Presets Settings" style="align-items: stretch; align-self: flex-start; margin-top: 3px; margin-bottom: 7px; -unity-font-style: bold; font-size: 13px; padding-left: 10px;" />
        <ui:Button text="Capture Weights" name="CopyWeights" tooltip="Reads the tiles weights (generation probability) from the current Layer, and applies them to the Exterior Tile Bundle in use." style="height: 40px; width: auto; margin-top: 3px; margin-bottom: 3px; align-self: stretch; padding-left: 0; padding-right: 0;" />
        <uie:ObjectField label="Current Bundle" type="LBS.Bundles.Bundle, LBS" style="width: auto; align-self: stretch;" />
        <uie:ToolbarSpacer style="height: 2px; width: auto; background-color: rgb(82, 82, 82); background-size: 100% 10%; margin-top: 5px; margin-bottom: 5px; align-self: stretch;" />
        <ui:TextField label="Preset Name" placeholder-text="New WFC Preset" value="New WFC Preset" name="PresetName" style="width: auto; margin-top: 3px; align-self: stretch;" />
        <ui:TextField label="Save Path" placeholder-text="filler text" name="PresetsPath" value="Assets//LBS/Artificial Intelligence/Assistants/WFCPresets" style="width: auto; margin-bottom: 3px; margin-top: 3px; align-self: stretch;" />
        <uie:ToolbarSpacer style="height: 2px; width: auto; background-color: rgb(82, 82, 82); background-size: 100% 10%; margin-top: 5px; margin-bottom: 5px; align-self: stretch;" />
        <ui:VisualElement style="flex-grow: initial; flex-direction: row; align-self: stretch; align-content: auto; justify-content: space-evenly; align-items: stretch; flex-wrap: nowrap;">
            <ui:Button text="Save Weights" name="SaveWeights" tooltip="Saves the captured weights to a new WFC preset, or overrides an existent preset with the same name." style="align-self: center; justify-content: flex-start; align-items: stretch; align-content: flex-start; height: 30px; -unity-text-align: middle-center; width: auto; flex-shrink: 0; flex-grow: 1;" />
            <ui:Button text="Load Weights" name="LoadWeights" tooltip="Loads saved weights from the selected WFC preset from the list below." style="align-self: center; height: 30px; flex-grow: 1;" />
        </ui:VisualElement>
        <uie:ObjectField label="Current Preset" type="ISILab.LBS.Assistants.WFCPreset, LBS" value="project://database/Assets//LBS/Artificial%20Intelligence/Assistants/WFCPresets/Default%20WFC%20Preset.asset?fileID=11400000&amp;guid=aa906d6d48e992141b714743bb35ff3a&amp;type=2#Default WFC Preset" name="CurrentPreset" enabled="false" picking-mode="Ignore" focusable="true" style="align-content: flex-start; align-items: stretch; align-self: stretch; margin-top: 3px; margin-bottom: 3px; display: flex; opacity: 1;" />
        <ui:ListView name="PresetsList" item-template="project://database/Assets//LBS/Artificial%20Intelligence/Assistants/Editor/WFCPresetElement.uxml?fileID=9197481963319205126&amp;guid=993e14f54f69e034ead5a72849f362a8&amp;type=3#WFCPresetElement" show-border="true" show-foldout-header="true" header-title="Presets" show-bound-collection-size="false" focusable="true" style="align-self: stretch;" />
        <uie:ToolbarSpacer style="height: 4px; width: auto; background-color: rgb(82, 82, 82); background-size: 100% 10%; margin-top: 10px; margin-bottom: 10px; align-self: stretch;" />
        <ui:Label text="WFC Settings" style="align-items: stretch; align-self: flex-start; margin-top: 0; margin-bottom: 0; -unity-font-style: bold; font-size: 13px; padding-left: 10px;" />
        <ISILab.LBS.CustomComponents.LBSCustomToggleField value="true" name="SafeMode" label="Safe Generation" tooltip="It forces the correct generation of all tiles. Deactivating it may cause incomplete generation." style="align-self: stretch; flex-direction: row; align-items: auto; justify-content: space-between; flex-wrap: nowrap; flex-shrink: 1; flex-grow: 0; flex-basis: auto; right: auto; align-content: flex-start; padding-left: 0; padding-right: 0; margin-left: 10px; margin-right: 10px;" />
    </ui:VisualElement>
</ui:UXML>
